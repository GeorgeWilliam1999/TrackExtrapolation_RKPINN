# =============================================================================
# HTCondor submit for MLP sweep
# =============================================================================

universe        = vanilla
executable      = /data/bfys/gscriven/TrackExtrapolation/experiments/gen_2/condor/run_training.sh
arguments       = /data/bfys/gscriven/TrackExtrapolation/experiments/gen_2/$(config_path)

request_cpus    = 1
request_memory  = 8GB
request_gpus    = 1
require_gpus    = (GlobalMemoryMb >= 16000)

output          = /data/bfys/gscriven/TrackExtrapolation/experiments/gen_2/condor/logs/$(ClusterId)_$(ProcId).out
error           = /data/bfys/gscriven/TrackExtrapolation/experiments/gen_2/condor/logs/$(ClusterId)_$(ProcId).err
log             = /data/bfys/gscriven/TrackExtrapolation/experiments/gen_2/condor/logs/$(ClusterId)_$(ProcId).log

getenv          = true
+UseOS          = "el9"
+JobCategory    = "long"

max_retries     = 1

queue config_path from jobs_mlp.txt
